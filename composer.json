{
    "name": "julienbohy/git-profiler-bundle",
    "description": "Displays Git information (branch, commit and working state) in the Symfony Web Profiler.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "bundle", "profiler", "git", "data-collector"],
    "homepage": "https://github.com/julienbohy/git-profiler-bundle",
    "support": {
        "issues": "https://github.com/julienbohy/git-profiler-bundle/issues",
        "source": "https://github.com/julienbohy/git-profiler-bundle"
    },
    "authors": [
        {
            "name": "Julien Bohy"
        }
    ],
    "require": {
        "php": ">=8.3",
        "gitonomy/gitlib": "^1.6",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/process": "^6.4 || ^7.0 || ^8.0",
        "symfony/twig-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/web-profiler-bundle": "^6.4 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "JulienBohy\\GitProfilerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JulienBohy\\GitProfilerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
