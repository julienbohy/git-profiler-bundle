{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% if collector.available %}
        {% set icon %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 3a3 3 0 0 0-1 5.83v6.34a3 3 0 1 0 2 0v-2.34c.88.62 1.94.83 3 .83 2.21 0 4-1.79 4-4V8.83A3 3 0 1 0 15 5.83 3 3 0 0 0 12 3a3 3 0 0 0-1 5.83V10c0 1.1-.9 2-2 2-1.06 0-2-.55-2-1.17V8.83A3 3 0 0 0 6 3m0 2a1 1 0 1 1 0 2 1 1 0 0 1 0-2m12 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2M6 17a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
            <span class="sf-toolbar-value">{{ collector.branch }}</span>
            {% if collector.dirty %}<span class="sf-toolbar-status sf-toolbar-status-yellow">●</span>{% endif %}
        {% endset %}

        {% set text %}
            <div class="sf-toolbar-info-piece">
                <b>Branche</b>
                <span>{{ collector.branch }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Commit</b>
                <span>{{ collector.shortCommit }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Working tree</b>
                <span>{{ collector.dirty ? 'dirty' : 'clean' }}</span>
            </div>
        {% endset %}

        {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: true }) }}
    {% endif %}
{% endblock %}

{% block menu %}
    <span class="label {{ not collector.available ? 'disabled' }}">
        <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 3a3 3 0 0 0-1 5.83v6.34a3 3 0 1 0 2 0v-2.34c.88.62 1.94.83 3 .83 2.21 0 4-1.79 4-4V8.83A3 3 0 1 0 15 5.83 3 3 0 0 0 12 3a3 3 0 0 0-1 5.83V10c0 1.1-.9 2-2 2-1.06 0-2-.55-2-1.17V8.83A3 3 0 0 0 6 3m0 2a1 1 0 1 1 0 2 1 1 0 0 1 0-2m12 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2M6 17a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
            </svg>
        </span>
        <strong>Git</strong>
    </span>
{% endblock %}

{% block panel %}
    <h2>Git</h2>

    {% if collector.available %}
        <div class="metrics">
            <div class="metric">
                <span class="value">{{ collector.branch }}</span>
                <span class="label">Branche</span>
            </div>
            <div class="metric">
                <span class="value"><code>{{ collector.shortCommit }}</code></span>
                <span class="label">Commit court</span>
            </div>
            <div class="metric">
                <span class="value">{{ collector.dirty ? 'Oui' : 'Non' }}</span>
                <span class="label">Modifications locales</span>
            </div>
        </div>
    {% else %}
        <div class="empty">
            <p>Ce répertoire n'est pas un dépôt Git (ou « git » est indisponible).</p>
        </div>
    {% endif %}
{% endblock %}
